# bill-payment-service — Environment Variable Template
# Copy to .env for local development. Never commit .env with real values.

# Database
DB_URL=jdbc:postgresql://localhost:5432/bill_payment_db
DB_USERNAME=billpayment
DB_PASSWORD=billpayment

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Auth — JWT
JWT_ISSUER_URI=http://localhost:9000
JWT_JWK_SET_URI=http://localhost:9000/.well-known/jwks.json

# AWS / LocalStack
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_OVERRIDE=http://localhost:4566

# Secrets Manager prefix for provider credentials
SECRETS_PREFIX=/bill-payment/providers

# Observability
OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Service identity (used in logs and audit trail)
SERVICE_NAME=bill-payment-service
SERVICE_VERSION=0.0.1
